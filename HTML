<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Manisha Marble Suppliers</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      scroll-behavior:smooth;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:#0f0f0f;
      color:white;
      overflow-x:hidden;
    }

    /* Animated Background */

    body::before{
      content:"";
      position:fixed;
      width:600px;
      height:600px;
      background:radial-gradient(circle,#ffffff15,transparent 70%);
      top:-200px;
      left:-150px;
      animation:float 10s ease-in-out infinite alternate;
      z-index:-1;
    }

    body::after{
      content:"";
      position:fixed;
      width:500px;
      height:500px;
      background:radial-gradient(circle,#c9b38d20,transparent 70%);
      bottom:-200px;
      right:-150px;
      animation:float2 12s ease-in-out infinite alternate;
      z-index:-1;
    }

    @keyframes float{
      from{
        transform:translateY(0px);
      }
      to{
        transform:translateY(60px);
      }
    }

    @keyframes float2{
      from{
        transform:translateY(0px);
      }
      to{
        transform:translateY(-60px);
      }
    }

    /* Navbar */

    nav{
      width:100%;
      padding:22px 8%;
      display:flex;
      justify-content:space-between;
      align-items:center;
      position:fixed;
      top:0;
      backdrop-filter:blur(10px);
      background:#00000035;
      z-index:1000;
    }

    nav h2{
      font-size:1.5rem;
      font-weight:600;
      letter-spacing:1px;
    }

    nav a{
      text-decoration:none;
      color:white;
      margin-left:25px;
      transition:0.3s;
    }

    nav a:hover{
      color:#d8b98a;
    }

    /* Hero */

    .hero{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      text-align:center;
      padding:120px 8%;
      flex-direction:column;
    }

    .hero h1{
      font-size:4rem;
      font-weight:700;
      line-height:1.1;
      margin-bottom:20px;
      background:linear-gradient(to right,#ffffff,#c9b38d);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .hero p{
      max-width:700px;
      color:#cfcfcf;
      font-size:1.1rem;
      line-height:1.8;
      margin-bottom:35px;
    }

    .hero button{
      padding:14px 32px;
      border:none;
      border-radius:50px;
      background:linear-gradient(135deg,#ffffff,#c9b38d);
      color:#111;
      font-size:1rem;
      font-weight:600;
      cursor:pointer;
      transition:0.4s;
    }

    .hero button:hover{
      transform:translateY(-5px) scale(1.03);
      box-shadow:0 10px 30px #c9b38d55;
    }

    /* About */

    .section{
      padding:100px 8%;
    }

    .section-title{
      font-size:2.5rem;
      margin-bottom:25px;
      color:#fff;
    }

    .about p{
      max-width:850px;
      line-height:1.9;
      color:#c9c9c9;
    }

    /* Services */

    .cards{
      margin-top:50px;
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:25px;
    }

    .card{
      background:#171717;
      border:1px solid #2b2b2b;
      border-radius:24px;
      padding:35px;
      transition:0.4s;
      position:relative;
      overflow:hidden;
    }

    .card::before{
      content:"";
      position:absolute;
      width:150px;
      height:150px;
      background:#c9b38d15;
      border-radius:50%;
      top:-50px;
      right:-50px;
    }

    .card:hover{
      transform:translateY(-8px);
      border-color:#c9b38d50;
      box-shadow:0 10px 40px #00000055;
    }

    .card h3{
      margin-bottom:15px;
      font-size:1.3rem;
    }

    .card p{
      color:#bdbdbd;
      line-height:1.7;
    }

    /* Footer */

    footer{
      padding:40px 8%;
      text-align:center;
      color:#9d9d9d;
      border-top:1px solid #2b2b2b;
      margin-top:50px;
    }

    /* Responsive */

    @media(max-width:768px){

      .hero h1{
        font-size:2.6rem;
      }

      nav{
        padding:18px 6%;
      }

      nav a{
        margin-left:12px;
        font-size:0.9rem;
      }

      .section-title{
        font-size:2rem;
      }
    }

  </style>
</head>
<body>

  <!-- Navbar -->

  <nav>
    <h2>Manisha Marble Suppliers</h2>

    <div>
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <!-- Hero Section -->

  <section class="hero">

    <h1>Elegant Marble.<br>Divine Creations.</h1>

    <p>
      Premium Marble Suppliers & Temple Construction Experts.
      Crafting timeless beauty with precision, tradition, and modern elegance.
    </p>

    <button>Explore Services</button>

  </section>

  <!-- About -->

  <section class="section about" id="about">

    <h2 class="section-title">About Us</h2>

    <p>
      Manisha Marble Suppliers specializes in high-quality marble supply
      and temple construction services. We blend traditional craftsmanship
      with modern architectural aesthetics to create elegant spaces,
      divine temples, and premium marble solutions for homes,
      businesses, and spiritual projects.
    </p>

  </section>

  <!-- Services -->

  <section class="section" id="services">

    <h2 class="section-title">Our Services</h2>

    <div class="cards">

      <div class="card">
        <h3>Premium Marble Supply</h3>
        <p>
          High-quality marble collections with elegant finishes
          for homes, interiors, exteriors, and luxury spaces.
        </p>
      </div>

      <div class="card">
        <h3>Temple Construction</h3>
        <p>
          Beautifully crafted marble temples designed with
          traditional artistry and modern durability.
        </p>
      </div>

      <div class="card">
        <h3>Custom Marble Work</h3>
        <p>
          Personalized marble designs, carvings, flooring,
          pillars, and decorative architectural work.
        </p>
      </div>

    </div>

  </section>

  <!-- Contact -->

  <section class="section" id="contact">

    <h2 class="section-title">Contact</h2>

    <p style="color:#bdbdbd; line-height:2;">
      📍 Manisha Marble Suppliers <br>
      📞 +91 XXXXX XXXXX <br>
      ✉️ yourmail@email.com
    </p>

  </section>

  <!-- Footer -->

  <footer>
    © 2026 Manisha Marble Suppliers • Crafted with Elegance
  </footer>

</body>
</html>